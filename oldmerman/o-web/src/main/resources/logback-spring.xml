<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true" scanPeriod="60 seconds">

    <!-- 把 Spring Boot 的属性暴露给 logback（可选） -->
    <springProperty scope="context" name="APP_NAME" source="spring.application.name" defaultValue="app"/>

    <!-- 日志文件目录（生产环境用） 测试环境D://cache-->
    <property name="LOG_DIR" value="/etc/oldmerman/log/system" />
    <!-- 日志文件名前缀 -->
    <property name="LOG_FILE_PREFIX" value="${APP_NAME}" />

    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %green([%thread]) %highlight(%-5level) %cyan(%logger{36}) - %msg%n" />

    <!-- 控制台输出（所有环境都可能用到） -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ============ 生产环境文件输出 ============ -->
    <!-- INFO 级别及以上 -->
    <springProfile name="prod">
        <!-- INFO 文件（附带滚动策略） -->
        <appender name="INFO_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <!-- 只记录 INFO 及以上（但排除 ERROR，让 ERROR 单独文件记录） -->
            <filter class="ch.qos.logback.classic.filter.LevelFilter">
                <level>INFO</level>
                <onMatch>ACCEPT</onMatch>
                <onMismatch>NEUTRAL</onMismatch>
            </filter>
            <filter class="ch.qos.logback.classic.filter.LevelFilter">
                <level>WARN</level>
                <onMatch>ACCEPT</onMatch>
                <onMismatch>NEUTRAL</onMismatch>
            </filter>
            <!-- 多个 LevelFilter 不太优雅，通常推荐用 Threshold/Janino，但这里按需求简单示例 -->

            <file>${LOG_DIR}/${LOG_FILE_PREFIX}-info.log</file>

            <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
                <!-- 按天滚动 -->
                <fileNamePattern>${LOG_DIR}/${LOG_FILE_PREFIX}-info.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
                <!-- 保存 30 天 -->
                <maxHistory>30</maxHistory>
            </rollingPolicy>

            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
                <charset>UTF-8</charset>
            </encoder>
        </appender>

        <!-- ERROR 文件 -->
        <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <!-- 只记录 ERROR 级别 -->
            <filter class="ch.qos.logback.classic.filter.LevelFilter">
                <level>ERROR</level>
                <onMatch>ACCEPT</onMatch>
                <onMismatch>DENY</onMismatch>
            </filter>

            <file>${LOG_DIR}/${LOG_FILE_PREFIX}-error.log</file>

            <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
                <fileNamePattern>${LOG_DIR}/${LOG_FILE_PREFIX}-error.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
                <maxHistory>30</maxHistory>
            </rollingPolicy>

            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
                <charset>UTF-8</charset>
            </encoder>
        </appender>

        <!-- 生产环境根日志配置：控制台 + 文件 -->
        <root level="INFO">
            <appender-ref ref="INFO_FILE" />
            <appender-ref ref="ERROR_FILE" />
        </root>
    </springProfile>

    <!-- ============ 测试环境配置（只控制台） ============ -->
    <springProfile name="dev">
        <root level="DEBUG">
            <appender-ref ref="CONSOLE" />
        </root>
    </springProfile>


</configuration>