<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="io.github.oldmerman.web.mapper.ArticleGroupLinkMapper">

    <insert id="insertBatch">
        INSERT INTO o_blog.o_article_group_link (group_id, article_id)
        VALUES
        <foreach collection="articleIds" item="articleId" separator=",">
            (#{groupId}, #{articleId})
        </foreach>
    </insert>
</mapper>

