<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="io.github.oldmerman.web.mapper.ArticleImageMapper">

    <select id="selectDanglingRecord" resultType="java.lang.String">
        SELECT oai.url FROM o_blog.o_article_img oai
        WHERE NOT EXISTS(
            SELECT 1 FROM o_blog.o_article oa WHERE oai.article_id = oa.id
        )
    </select>
</mapper>

